                </div>
                <div class="report-row">
                    <div class="report-label">诊断意见</div>
                    <div class="report-value" id="report-opinion">-</div>
                </div>
                <div class="report-row">
                    <div class="report-label">医嘱</div>
                    <div class="report-value" id="report-advice">-</div>
                </div>
            </div>

            <div class="card doctor-card">
                <div class="doctor-avatar" id="doctor-avatar">🎓</div>
                <div class="doctor-info">
                    <div class="doctor-name" id="doctor-name">-</div>
                    <div class="doctor-title" id="doctor-title">-</div>
                    <div class="doctor-quote" id="doctor-quote">-</div>
                </div>
            </div>

            <button class="btn btn-primary" style="margin-top: 20px;" onclick="goToPrescription()">查看处方单</button>
        </div>

        <!-- ==================== 处方页 ==================== -->
        <div id="screen-prescription" class="screen">
            <div class="back-link" onclick="goToDiagnosis()">
                <span>←</span> 返回诊断
            </div>

            <div class="progress-bar">
                <div class="progress-step completed">
                    <div class="progress-dot">✓</div>
                    <div class="progress-label">挂号</div>
                </div>
                <div class="progress-line completed"></div>
                <div class="progress-step completed">
                    <div class="progress-dot">✓</div>
                    <div class="progress-label">诊断</div>
                </div>
                <div class="progress-line completed"></div>
                <div class="progress-step active">
                    <div class="progress-dot">3</div>
                    <div class="progress-label">开方</div>
                </div>
                <div class="progress-line" id="line-prescription-3"></div>
                <div class="progress-step">
                    <div class="progress-dot">4</div>
                    <div class="progress-label">证书</div>
                </div>
            </div>

            <div class="rx-header">
                <h2 class="rx-title" id="rx-title">新学期处方单</h2>
                <p class="rx-subtitle">请按医嘱服用，状态重启指日可待</p>
            </div>

            <div class="card rx-card" id="rx-card">
                <!-- 处方内容动态生成 -->
            </div>

            <button class="btn btn-primary" style="margin-top: 20px;" onclick="goToCertificate()">领取重启证书</button>
        </div>

        <!-- ==================== 证书页 ==================== -->
        <div id="screen-certificate" class="screen">
            <div class="back-link" onclick="goToPrescription()">
                <span>←</span> 返回处方
            </div>

            <div class="progress-bar">
                <div class="progress-step completed">
                    <div class="progress-dot">✓</div>
                    <div class="progress-label">挂号</div>
                </div>
                <div class="progress-line completed"></div>
                <div class="progress-step completed">
                    <div class="progress-dot">✓</div>
                    <div class="progress-label">诊断</div>
                </div>
                <div class="progress-line completed"></div>
                <div class="progress-step completed">
                    <div class="progress-dot">✓</div>
                    <div class="progress-label">开方</div>
                </div>
                <div class="progress-line completed"></div>
                <div class="progress-step active">
                    <div class="progress-dot">4</div>
                    <div class="progress-label">证书</div>
                </div>
            </div>

            <div class="cert-header">
                <span class="cert-badge" id="cert-badge">诊断完成</span>
                <h2 class="cert-title" id="cert-title">新学期状态重启证书</h2>
            </div>

            <div class="card cert-card">
                <div class="cert-patient-id" id="cert-patient-id">-</div>
                <div class="cert-result" id="cert-result">-</div>
                <div class="cert-doctor" id="cert-doctor">-</div>
                <div class="cert-seal" id="cert-seal">B站<br>认证</div>
            </div>

            <div class="card flag-card">
                <div class="flag-title" id="flag-title">新学期 Flag 清单</div>
                <div id="flags-container">
                    <!-- Flag 动态生成 -->
                </div>
            </div>

            <div class="share-actions">
                <button class="btn btn-primary" id="btn-share" onclick="shareCertificate()">分享我的证书</button>
                <button class="btn btn-secondary" onclick="goToHome()">再挂一次号</button>
            </div>
        </div>

        <!-- ==================== 详情页 ==================== -->
        <div id="screen-details" class="screen">
            <div class="back-link" onclick="goToHome()">
                <span>←</span> 返回首页
            </div>

            <div class="details-header">
                <h2 class="details-title" id="details-title">活动方案详情</h2>
                <p class="details-subtitle">策略、洞察与目标人群</p>
            </div>

            <div id="details-container">
                <!-- 详情内容动态生成 -->
            </div>
        </div>
    </div>

    <script>

// ==================== 全局状态 ====================
let selectedSymptoms = [];
let currentDiagnosis = null;

// ==================== 初始化 ====================
document.addEventListener('DOMContentLoaded', function() {
    initHome();
    initRegister();
    initDetails();
});

// ==================== 页面切换 ====================
function switchScreen(screenId) {
    document.querySelectorAll('.screen').forEach(function(screen) {
        screen.classList.remove('active');
    });
    document.getElementById(screenId).classList.add('active');
    window.scrollTo(0, 0);
}

function goToHome() {
    selectedSymptoms = [];
    currentDiagnosis = null;
    updateSelectedCount();
    renderDepartments();
    switchScreen('screen-home');
}

function goToRegister() {
    switchScreen('screen-register');
}

function goToDiagnosis() {
    switchScreen('screen-diagnosis');
}

function goToPrescription() {
    renderPrescription();
    switchScreen('screen-prescription');
}

function goToCertificate() {
    renderCertificate();
    switchScreen('screen-certificate');
}

function goToDetails() {
    switchScreen('screen-details');
}

// ==================== 首页初始化 ====================
function initHome() {
    document.getElementById('home-title').textContent = CONFIG.home.title;
    document.getElementById('home-subtitle').textContent = CONFIG.home.subtitle;
    document.getElementById('btn-start').textContent = CONFIG.home.startBtnText;

    const featuresContainer = document.getElementById('home-features');
    featuresContainer.innerHTML = '';
    CONFIG.home.features.forEach(function(feature) {
        const span = document.createElement('span');
        span.className = 'home-feature-item';
        span.textContent = feature;
        featuresContainer.appendChild(span);
    });
}

// ==================== 挂号页初始化 ====================
function initRegister() {
    document.getElementById('register-title').textContent = CONFIG.register.title;
    document.getElementById('register-subtitle').textContent = CONFIG.register.subtitle;
    document.getElementById('btn-submit-register').textContent = CONFIG.register.submitBtnText;
    renderDepartments();
}

function renderDepartments() {
    const container = document.getElementById('departments-container');
    container.innerHTML = '';

    CONFIG.departments.forEach(function(dept) {
        const card = document.createElement('div');
        card.className = 'card department-card';

        const nameDiv = document.createElement('div');
        nameDiv.className = 'department-name';
        nameDiv.innerHTML = '<span class="department-icon">' + dept.icon + '</span>' + dept.name;
        card.appendChild(nameDiv);

        const symptomsRow = document.createElement('div');
        symptomsRow.className = 'symptoms-row';

        dept.symptoms.forEach(function(symptom) {
            const tag = document.createElement('span');
            tag.className = 'tag tag-default';
            tag.textContent = symptom.name;
            tag.dataset.id = symptom.id;
            tag.dataset.dept = dept.id;
            tag.dataset.name = symptom.name;
            tag.dataset.desc = symptom.desc;
            tag.onclick = function() { toggleSymptom(this); };
            symptomsRow.appendChild(tag);
        });

        card.appendChild(symptomsRow);
        container.appendChild(card);
    });
}

function toggleSymptom(tag) {
    const id = tag.dataset.id;
    const isSelected = tag.classList.contains('tag-selected');

    if (isSelected) {
        selectedSymptoms = selectedSymptoms.filter(function(s) { return s.id !== id; });
        tag.classList.remove('tag-selected');
        tag.classList.add('tag-default');
    } else {
        if (selectedSymptoms.length >= CONFIG.register.maxSelect) {
            showToast('最多只能选择 ' + CONFIG.register.maxSelect + ' 个症状哦');
            return;
        }
        selectedSymptoms.push({
            id: id,
            deptId: tag.dataset.dept,
            name: tag.dataset.name,
            desc: tag.dataset.desc
        });
        tag.classList.remove('tag-default');
        tag.classList.add('tag-selected');
    }

    updateSelectedCount();
}

function updateSelectedCount() {
    document.getElementById('selected-count').textContent = selectedSymptoms.length;
    const btn = document.getElementById('btn-submit-register');
    btn.disabled = selectedSymptoms.length < CONFIG.register.minSelect;
}

function submitRegister() {
    if (selectedSymptoms.length < CONFIG.register.minSelect) {
        showToast('请至少选择 ' + CONFIG.register.minSelect + ' 个症状');
        return;
    }
    generateDiagnosis();
    switchScreen('screen-diagnosis');
}

// ==================== 诊断生成 ====================
function generateDiagnosis() {
    // 找出最主要的科室（选择症状最多的科室）
    const deptCount = {};
    selectedSymptoms.forEach(function(s) {
        deptCount[s.deptId] = (deptCount[s.deptId] || 0) + 1;
    });

    let mainDeptId = '';
    let maxCount = 0;
    for (const deptId in deptCount) {
        if (deptCount[deptId] > maxCount) {
            maxCount = deptCount[deptId];
            mainDeptId = deptId;
        }
    }

    const mainDept = CONFIG.departments.find(function(d) { return d.id === mainDeptId; });
    const patientId = 'B站病友_' + new Date().getFullYear() + String(new Date().getMonth() + 1).padStart(2, '0') + String(new Date().getDate()).padStart(2, '0') + '_' + Math.floor(Math.random() * 9000 + 1000);

    // 匹配医生
    let doctor = CONFIG.doctors.find(function(d) {
        return d.departments.indexOf(mainDeptId) !== -1;
    });
    if (!doctor) {
        doctor = CONFIG.doctors[0];
    }

    // 随机诊断意见和医嘱
    const opinion = CONFIG.diagnosis.opinions[Math.floor(Math.random() * CONFIG.diagnosis.opinions.length)];
    const advice = CONFIG.diagnosis.advices[Math.floor(Math.random() * CONFIG.diagnosis.advices.length)];

    currentDiagnosis = {
        patientId: patientId,
        department: mainDept ? mainDept.name + '（' + mainDept.icon + '）' : '综合门诊',
        symptoms: selectedSymptoms.map(function(s) { return s.name; }).join('、'),
        mainSymptom: selectedSymptoms[0].name,
        opinion: opinion,
        advice: advice,
        doctor: doctor,
        mainDeptId: mainDeptId
    };

    // 渲染诊断页
    document.getElementById('report-patient-id').textContent = currentDiagnosis.patientId;
    document.getElementById('report-department').textContent = currentDiagnosis.department;
    document.getElementById('report-symptoms').textContent = currentDiagnosis.symptoms;
    document.getElementById('report-opinion').textContent = currentDiagnosis.opinion;
    document.getElementById('report-advice').textContent = currentDiagnosis.advice;

    document.getElementById('doctor-avatar').textContent = doctor.avatar;
    document.getElementById('doctor-name').textContent = doctor.name;
    document.getElementById('doctor-title').textContent = doctor.title;
    document.getElementById('doctor-quote').textContent = '"' + doctor.quote + '"';
}

// ==================== 处方页渲染 ====================
function renderPrescription() {
    if (!currentDiagnosis) return;

    const rxConfig = CONFIG.prescriptions[currentDiagnosis.mainDeptId] || CONFIG.prescriptions.knowledge;
    document.getElementById('rx-title').textContent = rxConfig.title;

    const rxCard = document.getElementById('rx-card');
    rxCard.innerHTML = '';

    rxConfig.items.forEach(function(item, index) {
        const rxItem = document.createElement('div');
        rxItem.className = 'rx-item';
        rxItem.innerHTML =
            '<div class="rx-number">' + (index + 1) + '</div>' +
            '<div class="rx-content">' +
                '<div class="rx-name">' + item.name + '</div>' +
                '<div class="rx-desc">' + item.desc + '</div>' +
                '<span class="rx-usage">' + item.usage + '</span>' +
            '</div>';
        rxCard.appendChild(rxItem);
    });

    const noteDiv = document.createElement('div');
    noteDiv.className = 'rx-doctor-note';
    noteDiv.textContent = currentDiagnosis.doctor.name + ' 医师寄语：' + rxConfig.doctorNote;
    rxCard.appendChild(noteDiv);
}

// ==================== 证书页渲染 ====================
function renderCertificate() {
    if (!currentDiagnosis) return;

    document.getElementById('cert-badge').textContent = CONFIG.certificate.badge;
    document.getElementById('cert-title').textContent = CONFIG.certificate.title;
    document.getElementById('cert-patient-id').textContent = '患者 ID：' + currentDiagnosis.patientId;
    document.getElementById('cert-result').textContent = '确诊为：' + currentDiagnosis.mainSymptom;
    document.getElementById('cert-doctor').textContent = '主治医师：' + currentDiagnosis.doctor.name;
    document.getElementById('cert-seal').innerHTML = CONFIG.certificate.seal.replace(/\n/g, '<br>');

    document.getElementById('flag-title').textContent = CONFIG.certificate.flagTitle;

    const flagsContainer = document.getElementById('flags-container');
    flagsContainer.innerHTML = '';
    CONFIG.certificate.flags.forEach(function(flag, index) {
        const item = document.createElement('div');
        item.className = 'flag-item';
        item.innerHTML =
            '<div class="flag-checkbox"></div>' +
            '<div class="flag-text">' + flag + '</div>';
        item.onclick = function() {
            item.classList.toggle('checked');
        };
        flagsContainer.appendChild(item);
    });

    document.getElementById('btn-share').textContent = CONFIG.certificate.shareBtnText;
}

// ==================== 分享功能 ====================
function shareCertificate() {
    if (!currentDiagnosis) return;

    const shareText = CONFIG.certificate.shareTextTemplate
        .replace('{symptom}', currentDiagnosis.mainSymptom)
        .replace('{doctor}', currentDiagnosis.doctor.name);

    if (navigator.share) {
        navigator.share({
            title: CONFIG.home.title,
            text: shareText,
            url: window.location.href
        }).catch(function() {
            copyToClipboard(shareText);
        });
    } else {
        copyToClipboard(shareText);
    }
}

function copyToClipboard(text) {
    if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(function() {
            showToast('分享文案已复制，去粘贴分享吧！');
        }).catch(function() {
            showToast(text);
        });
    } else {
        showToast(text);
    }
}

// ==================== 详情页初始化 ====================
function initDetails() {
    document.getElementById('details-title').textContent = CONFIG.details.title;

    const container = document.getElementById('details-container');
    container.innerHTML = '';

    CONFIG.details.sections.forEach(function(section) {
        const sectionDiv = document.createElement('div');
        sectionDiv.className = 'card details-section';

        const title = document.createElement('h3');
        title.textContent = section.title;
        sectionDiv.appendChild(title);

        if (section.paragraphs) {
            section.paragraphs.forEach(function(p) {
                const para = document.createElement('p');
                para.textContent = p;
                sectionDiv.appendChild(para);
            });
        }

        if (section.list) {
            const ul = document.createElement('ul');
            section.list.forEach(function(item) {
                const li = document.createElement('li');
                li.textContent = item;
                ul.appendChild(li);
            });
            sectionDiv.appendChild(ul);
        }

        container.appendChild(sectionDiv);
    });
}

// ==================== 提示弹窗 ====================
function showToast(message) {
    const toast = document.getElementById('toast');
    toast.textContent = message;
    toast.classList.add('show');
    setTimeout(function() {
        toast.classList.remove('show');
    }, 2500);
}
</script>
</body>
</html>
