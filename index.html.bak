        },
        canteen: {
            title: "食堂生存指南方",
            items: [
                { name: "宿舍小锅美食教程", desc: "在规则允许范围内改善伙食", usage: "周末按需服用" },
                { name: "校园周边美食探店", desc: "发现学校附近隐藏菜单", usage: "换口味时服用" },
                { name: "健康饮食搭配指南", desc: "食堂也能吃出营养均衡", usage: "每日餐前参考" }
            ],
