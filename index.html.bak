<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>不想开学门诊 · 专治各种不想上学的疑难杂症</title>
    <style>
        /* ==================== 基础样式重置 ==================== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bili-pink: #FB7299;
            --bili-pink-light: #FFE4EC;
            --bili-pink-dark: #E65A82;
            --doctor-blue: #4A90E2;
            --doctor-blue-light: #E8F4FD;
            --text-main: #333333;
            --text-sub: #666666;
            --text-light: #999999;
            --bg: #FFF5F8;
            --card-bg: #FFFFFF;
            --border: #FFE4EC;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
            background: var(--bg);
            color: var(--text-main);
            min-height: 100vh;
            line-height: 1.6;
            overflow-x: hidden;
        }

        #app {
            max-width: 480px;
            margin: 0 auto;
            min-height: 100vh;
            position: relative;
            background: var(--bg);
        }

        /* ==================== 通用组件 ==================== */
        .screen {
            display: none;
            min-height: 100vh;
            padding: 20px 20px 40px;
            animation: fadeIn 0.4s ease-out;
        }

        .screen.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .card {
            background: var(--card-bg);
            border-radius: 20px;
            padding: 24px;
            margin-bottom: 16px;
            box-shadow: 0 4px 20px rgba(251, 114, 153, 0.08);
            border: 1px solid var(--border);
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            padding: 16px 24px;
            border: none;
            border-radius: 30px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .btn-primary {
            background: var(--bili-pink);
            color: white;
            box-shadow: 0 4px 16px rgba(251, 114, 153, 0.35);
        }

        .btn-primary:hover {
            background: var(--bili-pink-dark);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(251, 114, 153, 0.45);
        }

        .btn-primary:disabled {
            background: #CCCCCC;
            box-shadow: none;
            cursor: not-allowed;
            transform: none;
        }

        .btn-secondary {
            background: white;
            color: var(--bili-pink);
            border: 2px solid var(--bili-pink);
        }

        .btn-secondary:hover {
            background: var(--bili-pink-light);
        }

        .btn-small {
            width: auto;
            padding: 10px 20px;
            font-size: 14px;
        }

        .tag {
            display: inline-block;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 500;
            margin: 4px;
            cursor: pointer;
            transition: all 0.2s ease;
            border: 2px solid transparent;
        }

        .tag-default {
            background: #F5F5F5;
            color: var(--text-sub);
            border-color: #EEEEEE;
        }

        .tag-default:hover {
            background: #EEEEEE;
        }

        .tag-selected {
            background: var(--bili-pink-light);
            color: var(--bili-pink-dark);
            border-color: var(--bili-pink);
        }

        .section-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .section-title .icon {
            font-size: 24px;
        }

        .subtitle {
            font-size: 14px;
            color: var(--text-sub);
            margin-bottom: 20px;
        }

        .highlight {
            color: var(--bili-pink);
            font-weight: 600;
        }

        /* ==================== 首页 ==================== */
        .home-screen {
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding-top: 60px;
        }

        .home-logo {
            width: 140px;
            height: 140px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 32px;
            box-shadow: 0 8px 32px rgba(251, 114, 153, 0.2);
            position: relative;
        }

        .tv-doctor {
            font-size: 80px;
            position: relative;
        }

        .tv-doctor::after {
            content: "🩺";
            font-size: 32px;
            position: absolute;
            bottom: -5px;
            right: -15px;
        }

        .home-title {
            font-size: 36px;
            font-weight: 800;
            color: var(--bili-pink);
            margin-bottom: 8px;
            letter-spacing: -1px;
        }

        .home-subtitle {
            font-size: 16px;
            color: var(--text-sub);
            margin-bottom: 40px;
            padding: 0 20px;
        }

        .home-features {
            display: flex;
            justify-content: center;
            gap: 12px;
            margin-bottom: 40px;
            flex-wrap: wrap;
            padding: 0 20px;
        }

        .home-feature-item {
            background: white;
            padding: 10px 16px;
            border-radius: 20px;
            font-size: 13px;
            color: var(--text-sub);
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .home-buttons {
            width: 100%;
            max-width: 320px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .home-detail-link {
            margin-top: 24px;
            color: var(--text-light);
            font-size: 14px;
            text-decoration: underline;
            cursor: pointer;
        }

        .home-detail-link:hover {
            color: var(--bili-pink);
        }

        /* ==================== 挂号页 ==================== */
        .register-header {
            text-align: center;
            margin-bottom: 24px;
        }

        .register-title {
            font-size: 26px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 4px;
        }

        .register-subtitle {
            font-size: 14px;
            color: var(--text-sub);
        }

        .department-card {
            margin-bottom: 16px;
        }

        .department-name {
            font-size: 16px;
            font-weight: 700;
            color: var(--bili-pink-dark);
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .department-icon {
            font-size: 20px;
        }

        .symptoms-row {
            display: flex;
            flex-wrap: wrap;
            margin: -4px;
        }

        .selected-count {
            text-align: center;
            font-size: 14px;
            color: var(--text-sub);
            margin: 20px 0;
        }

        .selected-count .count {
            color: var(--bili-pink);
            font-weight: 700;
            font-size: 18px;
        }

        /* ==================== 诊断页 ==================== */
        .report-header {
            text-align: center;
            margin-bottom: 24px;
        }

        .report-badge {
            display: inline-block;
            background: var(--doctor-blue);
            color: white;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 13px;
            margin-bottom: 12px;
        }

        .report-title {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-main);
        }

        .report-card {
            background: var(--doctor-blue-light);
            border: 1px solid #D0E8FA;
        }

        .report-row {
            display: flex;
            padding: 10px 0;
            border-bottom: 1px dashed #D0E8FA;
        }

        .report-row:last-child {
            border-bottom: none;
        }

        .report-label {
            width: 80px;
            color: var(--text-light);
            font-size: 14px;
            flex-shrink: 0;
        }

        .report-value {
            flex: 1;
            color: var(--text-main);
            font-size: 14px;
            font-weight: 500;
        }

        .doctor-card {
            display: flex;
            align-items: center;
            gap: 16px;
            background: white;
        }

        .doctor-avatar {
            width: 64px;
            height: 64px;
            border-radius: 50%;
            background: var(--bili-pink-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            flex-shrink: 0;
        }

        .doctor-info {
            flex: 1;
        }

        .doctor-name {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 4px;
        }

        .doctor-title {
            font-size: 13px;
            color: var(--bili-pink);
            margin-bottom: 6px;
        }

        .doctor-quote {
            font-size: 13px;
            color: var(--text-sub);
            font-style: italic;
        }

        /* ==================== 处方页 ==================== */
        .rx-header {
            text-align: center;
            margin-bottom: 24px;
        }

        .rx-title {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 4px;
        }

        .rx-subtitle {
            font-size: 14px;
            color: var(--text-sub);
        }

        .rx-card {
            background: linear-gradient(135deg, #FFF9FB 0%, #FFFFFF 100%);
            border: 2px solid var(--bili-pink);
            position: relative;
            overflow: hidden;
        }

        .rx-card::before {
            content: "Rx";
            position: absolute;
            top: 16px;
            right: 20px;
            font-size: 40px;
            font-weight: 800;
            color: var(--bili-pink);
            opacity: 0.15;
        }

        .rx-item {
            display: flex;
            gap: 12px;
            padding: 16px 0;
            border-bottom: 1px dashed var(--border);
        }

        .rx-item:last-child {
            border-bottom: none;
        }

        .rx-number {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: var(--bili-pink);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            flex-shrink: 0;
        }

        .rx-content {
            flex: 1;
        }

        .rx-name {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-main);
            margin-bottom: 4px;
        }

        .rx-desc {
            font-size: 13px;
            color: var(--text-sub);
            margin-bottom: 6px;
        }

        .rx-usage {
            font-size: 12px;
            color: var(--bili-pink-dark);
            background: var(--bili-pink-light);
            padding: 4px 10px;
            border-radius: 12px;
            display: inline-block;
        }

        .rx-doctor-note {
            background: var(--bili-pink-light);
            border-radius: 16px;
            padding: 16px;
            margin-top: 16px;
            font-size: 14px;
            color: var(--text-main);
            position: relative;
        }

        .rx-doctor-note::before {
            content: "💬";
            margin-right: 6px;
        }

        /* ==================== 证书页 ==================== */
        .cert-header {
            text-align: center;
            margin-bottom: 24px;
        }

        .cert-badge {
            display: inline-block;
            background: var(--bili-pink);
            color: white;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 13px;
            margin-bottom: 12px;
        }

        .cert-title {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-main);
        }

        .cert-card {
            background: linear-gradient(135deg, #FFFFFF 0%, #FFF9FB 100%);
            border: 3px solid var(--bili-pink);
            text-align: center;
            position: relative;
        }

        .cert-card::before,
        .cert-card::after {
            content: "✦";
            position: absolute;
            color: var(--bili-pink);
            font-size: 20px;
            opacity: 0.3;
        }

        .cert-card::before {
            top: 16px;
            left: 16px;
        }

        .cert-card::after {
            bottom: 16px;
            right: 16px;
        }

        .cert-patient-id {
            font-size: 13px;
            color: var(--text-light);
            margin-bottom: 8px;
        }

        .cert-result {
            font-size: 22px;
            font-weight: 800;
            color: var(--bili-pink);
            margin-bottom: 12px;
        }

        .cert-doctor {
            font-size: 14px;
            color: var(--text-sub);
            margin-bottom: 16px;
        }

        .cert-seal {
            display: inline-block;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            border: 3px solid var(--bili-pink);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
            color: var(--bili-pink);
            font-size: 12px;
            font-weight: 700;
            transform: rotate(-15deg);
        }

        .flag-card {
            text-align: left;
        }

        .flag-title {
            font-size: 16px;
            font-weight: 700;
            margin-bottom: 14px;
            color: var(--text-main);
        }

        .flag-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 0;
            border-bottom: 1px solid #F5F5F5;
            font-size: 14px;
            color: var(--text-sub);
            cursor: pointer;
        }

        .flag-item:last-child {
            border-bottom: none;
        }

        .flag-checkbox {
            width: 18px;
            height: 18px;
            border: 2px solid var(--bili-pink);
            border-radius: 4px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all 0.2s;
        }

        .flag-item.checked .flag-checkbox {
            background: var(--bili-pink);
        }

        .flag-item.checked .flag-checkbox::after {
            content: "✓";
            color: white;
            font-size: 12px;
            font-weight: 700;
        }

        .flag-item.checked .flag-text {
            color: var(--text-main);
            text-decoration: line-through;
            opacity: 0.6;
        }

        .share-actions {
            display: flex;
            gap: 12px;
            margin-top: 20px;
        }

        .share-actions .btn {
            flex: 1;
        }

        /* ==================== 详情页 ==================== */
        .details-header {
            text-align: center;
            margin-bottom: 24px;
        }

        .details-title {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 8px;
        }

        .details-subtitle {
            font-size: 14px;
            color: var(--text-sub);
        }

        .details-section {
            margin-bottom: 20px;
        }

        .details-section h3 {
            font-size: 17px;
            font-weight: 700;
            color: var(--bili-pink-dark);
            margin-bottom: 10px;
        }

        .details-section p {
            font-size: 14px;
            color: var(--text-sub);
            margin-bottom: 8px;
        }

        .details-section ul {
            list-style: none;
            padding-left: 0;
        }

        .details-section li {
            font-size: 14px;
            color: var(--text-sub);
            padding: 6px 0;
            padding-left: 18px;
            position: relative;
        }

        .details-section li::before {
            content: "•";
            color: var(--bili-pink);
            font-weight: 700;
            position: absolute;
            left: 0;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            color: var(--bili-pink);
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            margin-bottom: 20px;
        }

        /* ==================== 顶部进度条 ==================== */
        .progress-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            padding: 0 10px;
        }

        .progress-step {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            flex: 1;
        }

        .progress-dot {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: #EEEEEE;
            color: var(--text-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: 700;
        }

        .progress-step.active .progress-dot {
            background: var(--bili-pink);
            color: white;
        }

        .progress-step.completed .progress-dot {
            background: var(--bili-pink-dark);
            color: white;
        }

        .progress-line {
            flex: 1;
            height: 2px;
            background: #EEEEEE;
            margin: 0 4px;
            margin-top: -14px;
        }

        .progress-line.completed {
            background: var(--bili-pink-dark);
        }

        .progress-label {
            font-size: 11px;
            color: var(--text-light);
        }

        .progress-step.active .progress-label {
            color: var(--bili-pink);
            font-weight: 600;
        }

        /* ==================== 提示弹窗 ==================== */
        .toast {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(0, 0, 0, 0.8);
            color: white;
            padding: 16px 28px;
            border-radius: 12px;
            font-size: 14px;
            z-index: 1000;
            display: none;
            text-align: center;
            max-width: 80%;
        }

        .toast.show {
            display: block;
            animation: fadeIn 0.3s ease;
        }

        /* ==================== 响应式微调 ==================== */
        @media (max-width: 380px) {
            .home-title {
                font-size: 30px;
            }
            .card {
                padding: 18px;
            }
        }
    </style>
</head>
<body>

<!-- ==================== 可编辑配置区 START ==================== -->
<!--
  这里是 H5 的可编辑配置区。
  如果你需要修改症状、UP主、处方内容、Flag、文案等，只需要改下面的 CONFIG 对象即可，
  不需要改动下面的 HTML/JS 代码。
-->
<script>
const CONFIG = {
    // 首页文案
    home: {
        title: "不想开学门诊",
        subtitle: "专治各种不想上学的疑难杂症",
        features: ["免费挂号", "名医坐诊", "当场开方", "立即重启"],
        startBtnText: "去挂号",
        detailLinkText: "查看活动方案详情"
    },

    // 挂号页文案
    register: {
        title: "今天挂什么科？",
        subtitle: "勾选你的开学疑难杂症，最多选 3 个",
        submitBtnText: "提交挂号",
        minSelect: 1,
        maxSelect: 3
    },

    // 科室和症状配置
    departments: [
        {
            id: "knowledge",
            name: "知识蒸发科",
            icon: "🧠",
            symptoms: [
                { id: "k1", name: "知识已蒸发", desc: "暑假把脑子格式化了" },
                { id: "k2", name: "CPU冒烟症", desc: "一看到课表CPU开始冒烟" },
                { id: "k3", name: "DDL提前焦虑", desc: "DDL还没开始已经焦虑" }
            ]
        },
        {
            id: "biological",
            name: "生物钟抢救科",
            icon: "⏰",
            symptoms: [
                { id: "b1", name: "凌晨三点还在线", desc: "生物钟仍停留在凌晨三点" },
                { id: "b2", name: "早八昏迷综合征", desc: "听到早八就失去意识" },
                { id: "b3", name: "起床困难晚期", desc: "床上有强力磁铁吸住我" }
            ]
        },
        {
            id: "social",
            name: "社交重启科",
            icon: "💬",
            symptoms: [
                { id: "s1", name: "社恐系统回滚", desc: "社交能力退回到出厂设置" },
                { id: "s2", name: "同学名字已丢失", desc: "一个假期过去名字全忘了" },
                { id: "s3", name: "想社交但不会开场", desc: "想认识新朋友但开口即尴尬" }
            ]
        },
        {
            id: "pe",
            name: "体测防御科",
            icon: "🏃",
            symptoms: [
                { id: "p1", name: "800米恐惧症", desc: "听到800米就腿软" },
                { id: "p2", name: "坐位体前屈僵硬", desc: "身体硬得像块钢板" },
                { id: "p3", name: "引体向上绝缘体", desc: "和单杠之间只有重力" }
            ]
        },
        {
            id: "canteen",
            name: "食堂厌倦科",
            icon: "🍱",
            symptoms: [
                { id: "c1", name: "食堂吃一周就emo", desc: "看到食堂菜单就失去梦想" },
                { id: "c2", name: "暑假胃被养刁了", desc: "妈妈的饭把胃惯坏了" },
                { id: "c3", name: "不知道吃什么", desc: "每天三顿都是选择困难症" }
            ]
        },
        {
            id: "entertainment",
            name: "娱乐戒断科",
            icon: "🎮",
            symptoms: [
                { id: "e1", name: "追番太快乐不想回现实", desc: "番剧世界的引力太强" },
                { id: "e2", name: "游戏赛季结束人也结束", desc: "排位还没打完就要开学" },
                { id: "e3", name: "UP主暑假失联", desc: "我关注的UP主都去哪儿了" }
            ]
        }
    ],

    // UP主医生配置
    doctors: [
        {
            id: "bdao",
            name: "毕导THU",
            title: "学习/科研方法科主任",
            avatar: "🎓",
            quote: "你的大脑不是被格式化了，是在等待一个更强的操作系统。",
            departments: ["knowledge"]
        },
        {
            id: "luoxiang",
            name: "罗翔说刑法",
            title: "人生哲学与法学主任医师",
            avatar: "⚖️",
            quote: "人生唯一确定的就是不确定的人生，但开学这件事可以先试着接受。",
            departments: ["social", "biological"]
        },
        {
            id: "pamela",
            name: "帕梅拉Pamela",
            title: "运动健康科主任",
            avatar: "💪",
            quote: "体测不是敌人，是你和更好自己的一次会面。",
            departments: ["pe", "canteen"]
        },
        {
            id: "hexuan",
            name: "老师好我叫何同学",
            title: "科技灵感主治医师",
            avatar: "📱",
            quote: "看完了爆肝视频，你还好意思继续昏迷吗？",
            departments: ["biological", "knowledge"]
        },
        {
            id: "fan",
            name: "泛式",
            title: "动漫杂谈科主任",
            avatar: "🎬",
            quote: "新番导视已更新，现实世界的番剧也不会让你失望。",
            departments: ["entertainment"]
        },
        {
            id: "xiaoyao",
            name: "逍遥散人",
            title: "游戏心态科主治医师",
            avatar: "🎮",
            quote: "从受苦中找到乐趣，开学不过是一场新的游戏关卡。",
            departments: ["entertainment", "social"]
        }
    ],

    // 处方库配置
    prescriptions: {
        knowledge: {
            title: "知识重启方",
            items: [
                { name: "B站课堂专区《开学第一课》", desc: "由名师带你3小时重构知识体系", usage: "每日1课时，连续服用3天" },
                { name: "取景框看世界《大学如何不虚度》", desc: "从目标管理到时间规划一网打尽", usage: "睡前观看，笔记服用" },
                { name: "毕导THU学习方法合集", desc: "用科学方法治愈知识蒸发", usage: "焦虑时按需服用" }
            ],
            doctorNote: "禁止自我怀疑，你只是需要一个'哔'的一声重启。"
        },
        biological: {
            title: "生物钟校准方",
            items: [
                { name: "早八人专属闹铃合集", desc: "B站搜索'早八人 闹铃'", usage: "设为起床闹钟，每日清晨1次" },
                { name: "宿舍友好型运动视频", desc: "5分钟唤醒身体，不需要去操场", usage: "起床后立即服用" },
                { name: "助眠白噪音/ASMR", desc: "让大脑知道晚上该关机了", usage: "睡前30分钟服用" }
            ],
            doctorNote: "调整作息就像调时差，给自己一周时间。"
        },
        social: {
            title: "社交系统重启方",
            items: [
                { name: "罗翔老师人生金句合集", desc: "治愈社恐，从理解人性开始", usage: "社交前服用，增强底气" },
                { name: "聊天开场话题指南", desc: "从'你也来了'到真实对话", usage: "见面前预习" },
                { name: "社团招新/兴趣小组推荐", desc: "找到同好，社交自然发生", usage: "开学后按需加入" }
            ],
