        pe: {
            title: "体测防御强化方",
            items: [
                { name: "帕梅拉宿舍友好训练", desc: "不需要器材，只需要一块瑜伽垫", usage: "每周3次，每次20分钟" },
                { name: "800米/1000米呼吸节奏指南", desc: "科学配速，跑完不躺", usage: "体测前一周服用" },
                { name: "拉伸放松跟练", desc: "体测后修复套餐", usage: "运动后服用" }
            ],
