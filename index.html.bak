    // 证书页文案
    certificate: {
        title: "新学期状态重启证书",
        badge: "诊断完成",
        seal: "B站\n认证",
        flagTitle: "新学期 Flag 清单",
        flags: [
            "这学期绝不挂科",
            "早八成功起床率提高到 80%",
            "每周坚持看一部纪录片",
            "学会一个剪辑软件，当个 UP 主",
            "交到一个能一起看番的挚友"
        ],
        restartBtnText: "领取证书",
        shareBtnText: "分享我的证书",
        retryBtnText: "再挂一次号",
        shareTextTemplate: "我在 B 站「不想开学门诊」挂了号，确诊为【{symptom}】。主治医师 {doctor} 给我开了新学期处方单，状态重启中……你也来挂个号吧！"
    },

    // 详情页内容
    details: {
        title: "活动方案详情",
        sections: [
            {
                title: "项目背景",
                paragraphs: [
                    "每年开学季前后，'不想开学'都会成为社交媒体上的高频情绪词。这种情绪不是简单的'懒'或'厌学'，而是年轻人在假期自由节奏与开学规训节奏之间切换时的正常应激反应。",
                    "B站作为年轻人密度最高的内容社区，天然承接了这类情绪的表达和消解。"
                ]
            },
            {
                title: "用户洞察",
                paragraphs: [
                    "开学焦虑主要来自四个层面的'掉线'：学习层面（知识遗忘、DDL焦虑）、生活层面（生物钟紊乱、食堂厌倦、体测恐惧）、社交层面（社恐复发、忘记同学名字）、娱乐层面（追番/游戏停不下来）。",
                    "核心机会：用户需要的不是被教育'要振作'，而是被理解、被调侃、被给到一个轻松的过渡仪式。"
                ]
            },
            {
                title: "目标人群",
                list: [
                    "主要人群：18-24岁大学生与准大学生",
                    "泛化人群：高中生、研究生、年轻职场新人",
                    "品牌侧人群：B站老用户与轻度用户"
                ]
            },
            {
                title: "品牌目标",
                list: [
                    "短期：提升开学季站内活动参与度和话题讨论量",
                    "中期：强化'B站懂年轻人开学焦虑'的平台心智",
                    "长期：推动B站从娱乐平台向年轻人生活解决方案平台认知延伸"
                ]
            },
            {
                title: "玩法链路",
                list: [
                    "Step 1：挂号 — 选择开学疑难杂症",
                    "Step 2：诊断 — UP主医生出具电子诊断单",
                    "Step 3：开方 — 生成B站专属内容处方单",
                    "Step 4：证书 — 领取新学期状态重启证书并分享"
                ]
            }
        ],
        backText: "返回首页"
    }
};
</script>
<!-- ==================== 可编辑配置区 END ==================== -->

    <div id="app">
        <!-- 提示弹窗 -->
        <div id="toast" class="toast"></div>

        <!-- ==================== 首页 ==================== -->
        <div id="screen-home" class="screen active home-screen">
            <div class="home-logo">
                <div class="tv-doctor">📺</div>
            </div>
            <h1 class="home-title" id="home-title">不想开学门诊</h1>
            <p class="home-subtitle" id="home-subtitle">专治各种不想上学的疑难杂症</p>
            <div class="home-features" id="home-features">
                <span class="home-feature-item">免费挂号</span>
                <span class="home-feature-item">名医坐诊</span>
                <span class="home-feature-item">当场开方</span>
                <span class="home-feature-item">立即重启</span>
            </div>
            <div class="home-buttons">
                <button class="btn btn-primary" id="btn-start" onclick="goToRegister()">去挂号</button>
                <button class="btn btn-secondary" onclick="goToDetails()">查看活动方案详情</button>
            </div>
        </div>

        <!-- ==================== 挂号页 ==================== -->
        <div id="screen-register" class="screen">
            <div class="back-link" onclick="goToHome()">
                <span>←</span> 返回首页
            </div>

            <div class="progress-bar">
                <div class="progress-step active">
                    <div class="progress-dot">1</div>
                    <div class="progress-label">挂号</div>
                </div>
                <div class="progress-line" id="line-register"></div>
                <div class="progress-step">
                    <div class="progress-dot">2</div>
                    <div class="progress-label">诊断</div>
                </div>
                <div class="progress-line" id="line-diagnosis"></div>
                <div class="progress-step">
                    <div class="progress-dot">3</div>
                    <div class="progress-label">开方</div>
                </div>
                <div class="progress-line" id="line-prescription"></div>
                <div class="progress-step">
                    <div class="progress-dot">4</div>
                    <div class="progress-label">证书</div>
                </div>
            </div>

            <div class="register-header">
                <h2 class="register-title" id="register-title">今天挂什么科？</h2>
                <p class="register-subtitle" id="register-subtitle">勾选你的开学疑难杂症，最多选 3 个</p>
            </div>

            <div id="departments-container">
                <!-- 科室卡片会在这里动态生成 -->
            </div>

            <div class="selected-count">
                已选择 <span class="count" id="selected-count">0</span> 个症状
            </div>

            <button class="btn btn-primary" id="btn-submit-register" onclick="submitRegister()" disabled>提交挂号</button>
        </div>

        <!-- ==================== 诊断页 ==================== -->
        <div id="screen-diagnosis" class="screen">
            <div class="back-link" onclick="goToRegister()">
                <span>←</span> 重新挂号
            </div>

            <div class="progress-bar">
                <div class="progress-step completed">
                    <div class="progress-dot">✓</div>
                    <div class="progress-label">挂号</div>
                </div>
                <div class="progress-line completed"></div>
                <div class="progress-step active">
                    <div class="progress-dot">2</div>
                    <div class="progress-label">诊断</div>
                </div>
                <div class="progress-line" id="line-diagnosis-2"></div>
                <div class="progress-step">
                    <div class="progress-dot">3</div>
                    <div class="progress-label">开方</div>
                </div>
                <div class="progress-line" id="line-prescription-2"></div>
                <div class="progress-step">
                    <div class="progress-dot">4</div>
                    <div class="progress-label">证书</div>
                </div>
            </div>

            <div class="report-header">
                <span class="report-badge">电子诊断单</span>
                <h2 class="report-title">诊断报告</h2>
            </div>

            <div class="card report-card">
                <div class="report-row">
                    <div class="report-label">患者 ID</div>
                    <div class="report-value" id="report-patient-id">-</div>
                </div>
                <div class="report-row">
                    <div class="report-label">挂号科室</div>
                    <div class="report-value" id="report-department">-</div>
                </div>
                <div class="report-row">
                    <div class="report-label">主诉症状</div>
